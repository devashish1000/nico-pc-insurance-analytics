{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nico-pc-insurance-analytics.example/schemas/benchmark-result-1.0.0.json",
  "title": "NICO P&C pipeline benchmark result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "createdAt",
    "benchmark",
    "environment",
    "database",
    "timing",
    "pipeline",
    "loadMetrics",
    "stageDurations",
    "queryLatency",
    "explainAnalyze",
    "counts",
    "quality",
    "thresholds",
    "passed",
    "failures"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "createdAt": { "type": "string", "format": "date-time" },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "seed", "premiumRows", "claimRows", "totalRows", "from", "to", "calculationAsOf"],
      "properties": {
        "mode": { "enum": ["smoke", "primary", "extended"] },
        "seed": { "type": "integer" },
        "premiumRows": { "type": "integer", "minimum": 0 },
        "claimRows": { "type": "integer", "minimum": 0 },
        "totalRows": { "type": "integer", "minimum": 1 },
        "from": { "type": "string", "format": "date" },
        "to": { "type": "string", "format": "date" },
        "calculationAsOf": { "type": "string", "format": "date" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitSha", "nodeVersion", "ci"],
      "properties": {
        "gitSha": { "type": "string" },
        "nodeVersion": { "type": "string" },
        "ci": { "type": "boolean" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postgresVersion"],
      "properties": {
        "postgresVersion": { "type": "string", "minLength": 1 }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seedMs", "pipelineMs", "totalMs", "rowsPerSecond"],
      "properties": {
        "seedMs": { "type": "integer", "minimum": 0 },
        "pipelineMs": { "type": "integer", "minimum": 0 },
        "totalMs": { "type": "integer", "minimum": 0 },
        "rowsPerSecond": { "type": "number", "minimum": 0 }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": true,
      "required": ["response"],
      "properties": {
        "response": { "type": "object" },
        "runId": { "type": ["string", "null"], "format": "uuid" },
        "status": { "type": ["string", "null"] }
      }
    },
    "loadMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRows", "insertedRows", "updatedRows", "unchangedRows", "deduplicatedRows", "recalculatedRows", "rejectedRows"],
      "properties": {
        "sourceRows": { "type": "integer", "minimum": 0 },
        "insertedRows": { "type": "integer", "minimum": 0 },
        "updatedRows": { "type": "integer", "minimum": 0 },
        "unchangedRows": { "type": "integer", "minimum": 0 },
        "deduplicatedRows": { "type": "integer", "minimum": 0 },
        "recalculatedRows": { "type": "integer", "minimum": 0 },
        "rejectedRows": { "type": "integer", "minimum": 0 }
      }
    },
    "stageDurations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "name", "status", "durationMs", "inputRows", "insertedRows", "updatedRows", "unchangedRows", "recalculatedRows", "rejectedRows"],
        "properties": {
          "order": { "type": "integer", "minimum": 0 },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "durationMs": { "type": ["integer", "null"], "minimum": 0 },
          "inputRows": { "type": "integer", "minimum": 0 },
          "insertedRows": { "type": "integer", "minimum": 0 },
          "updatedRows": { "type": "integer", "minimum": 0 },
          "unchangedRows": { "type": "integer", "minimum": 0 },
          "recalculatedRows": { "type": "integer", "minimum": 0 },
          "rejectedRows": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "queryLatency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samples", "p50Ms", "p95Ms", "queries"],
      "properties": {
        "samples": { "type": "integer", "minimum": 1 },
        "p50Ms": { "type": "number", "minimum": 0 },
        "p95Ms": { "type": "number", "minimum": 0 },
        "queries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "samples", "p50Ms", "p95Ms"],
            "properties": {
              "name": { "type": "string" },
              "samples": { "type": "integer", "minimum": 1 },
              "p50Ms": { "type": "number", "minimum": 0 },
              "p95Ms": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "explainAnalyze": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portfolioKpis", "lobPerformance", "pipelineEvidence"],
      "properties": {
        "portfolioKpis": { "type": "array", "minItems": 1 },
        "lobPerformance": { "type": "array", "minItems": 1 },
        "pipelineEvidence": { "type": "array", "minItems": 1 }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stagedPremium", "stagedClaims", "premiumFacts", "lossFacts", "stageRuns", "quarantined"],
      "properties": {
        "stagedPremium": { "type": "integer", "minimum": 0 },
        "stagedClaims": { "type": "integer", "minimum": 0 },
        "premiumFacts": { "type": "integer", "minimum": 0 },
        "lossFacts": { "type": "integer", "minimum": 0 },
        "stageRuns": { "type": "integer", "minimum": 0 },
        "quarantined": { "type": "integer", "minimum": 0 }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "total", "failed"],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxTotalMs", "expectedTotalRows"],
      "properties": {
        "maxTotalMs": { "type": "integer", "minimum": 1 },
        "expectedTotalRows": { "type": "integer", "minimum": 1 }
      }
    },
    "passed": { "type": "boolean" },
    "failures": { "type": "array", "items": { "type": "string" } }
  }
}
